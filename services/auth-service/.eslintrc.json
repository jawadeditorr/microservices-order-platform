{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": ["airbnb-base"],
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "rules": {
    "no-console": "off",
    "consistent-return": "off",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "import/no-extraneous-dependencies": ["error", { "devDependencies": ["**/__tests__/**"] }]
  }
}
